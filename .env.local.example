# --- Required everywhere ---
INTERVIEWER_PASSWORD=Caonyx2024!
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars

# --- Local dev only ---
PORT=3002

# --- Production: durable session storage ---
# Use Upstash Redis (or Vercel KV — same protocol, just different env var names).
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
# Or, if you wired Vercel KV instead:
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...

# --- Production: external Y.js WebSocket host ---
# Deploy ws-server.mjs on Render/Railway/Fly and put its URL here.
# Without this the client will try same-origin /yjs, which Vercel can't serve.
# NEXT_PUBLIC_YJS_URL=wss://your-ws-host.example.com
